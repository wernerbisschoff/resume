#!/bin/bash
# Pre-commit hook - Run validation checks for all projects in monorepo

set -e

ROOT="$(git rev-parse --show-toplevel)"

echo "🔍 Running pre-commit checks..."

# CV Project (Typst)
echo "--- CV Project (Typst) ---"
cd "$ROOT" && mise run check

# Website (Astro) — check + production build (Layout slot rendering)
echo "--- Website (Astro) ---"
cd "$ROOT/website" && mise run check
cd "$ROOT/website" && npm run build > /tmp/website-build.log 2>&1 || { cat /tmp/website-build.log; exit 1; }

echo "✅ Pre-commit checks passed"
