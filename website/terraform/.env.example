# Cloudflare Credentials for Terraform
# Source this file before running terraform commands: source .env
export TF_VAR_cloudflare_api_token="..."
export TF_VAR_cloudflare_account_id="..."
# R2 Access Keys for Terraform S3 Backend
# Create these in Cloudflare dashboard: R2 > Manage R2 API Tokens
# These are AWS-compatible credentials for accessing R2 as an S3 endpoint
export AWS_ACCESS_KEY_ID="..."
export AWS_SECRET_ACCESS_KEY="..."
