---
/**
 * InteractiveElement — Engineer's Notebook
 *
 * Wraps an interactive element. With hoverScale=1 / activeScale=1 (the
 * defaults), the JS animation calls are no-ops and CSS handles the hover
 * feedback via color/border changes — engineering tools don't bounce.
 *
 * Pass scale values > 1 only when you genuinely need a scale animation.
 */

export interface Props {
  hover?: boolean;
  active?: boolean;
  hoverScale?: number;
  activeScale?: number;
  class?: string;
  tag?: 'div' | 'button' | 'a';
  href?: string;
  type?: string;
}

const {
  hover = true,
  active = true,
  hoverScale = 1,
  activeScale = 1,
  class: className = '',
  tag = 'div',
  href,
  type,
} = Astro.props;

const Tag = tag;
const attrs = href ? { href } : type === 'button' ? { type } : {};
const safeAttrs = attrs as Record<string, string | undefined>;
---

<Tag
  class:list={['interactive-element', className]}
  data-hover={String(hover)}
  data-active={String(active)}
  data-hover-scale={String(hoverScale)}
  data-active-scale={String(activeScale)}
  {...safeAttrs}
>
  <slot />
</Tag>

<script>
  import { shouldAnimate } from '~/utils/a11y';

  document.querySelectorAll('.interactive-element').forEach((element) => {
    if (!(element instanceof HTMLElement)) return;
    if (!shouldAnimate()) return;

    const hoverEnabled = element.dataset.hover === 'true';
    const activeEnabled = element.dataset.active === 'true';
    const hScale = parseFloat(element.dataset.hoverScale || '1');
    const aScale = parseFloat(element.dataset.activeScale || '1');
    const duration = 150;
    const easing = 'ease-out';

    // Skip wiring entirely when scales are 1 — CSS handles feedback.
    if (hScale === 1 && aScale === 1) return;

    if (hoverEnabled) {
      element.addEventListener('mouseenter', () => {
        element.animate({ transform: [`scale(1)`, `scale(${hScale})`] }, { duration, easing, fill: 'forwards' });
      });
      element.addEventListener('mouseleave', () => {
        element.animate(
          { transform: [`scale(${hScale})`, `scale(1)`] },
          { duration: duration * 1.5, easing, fill: 'forwards' }
        );
      });
    }

    if (activeEnabled) {
      element.addEventListener('mousedown', () => {
        element.animate(
          { transform: [`scale(${hScale || 1})`, `scale(${aScale})`] },
          { duration: duration / 2, easing, fill: 'forwards' }
        );
      });
      element.addEventListener('mouseup', () => {
        element.animate(
          { transform: [`scale(${aScale})`, `scale(${hScale || 1})`] },
          { duration, easing, fill: 'forwards' }
        );
      });
    }
  });
</script>
