---
import { SITE } from 'astrowind:config';

/**
 * Wordmark — Geist Pixel Circle signature
 *
 * Renders "werner bisschoff" in lowercase Pixel Circle. The pixel
 * font gives the site its identity moment in the header.
 */
---

<a href="/" class="flex items-center text-ink-heading hover:text-amber" aria-label={`${SITE?.name} Home`}>
  <span class="font-pixel text-base md:text-lg leading-none tracking-wide">werner bisschoff</span>
</a>

<style>
  .font-pixel {
    font-family: 'Geist Pixel Circle', monospace;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
</style>
