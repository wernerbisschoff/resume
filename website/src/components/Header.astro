---
/**
 * Header Component — Engineer's Notebook
 *
 * Sticky header with restrained hairline border, no backdrop blur,
 * no glow. Active link gets an amber underline. No rounded corners.
 * Mobile menu uses a simple stack with the same restraint.
 */

import { headerData } from '~/navigation';
import { getCollection } from 'astro:content';
import Logo from '~/components/Logo.astro';

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};

// Get published blog posts to determine if Notes link should be shown
const allPosts = await getCollection('post');
const publishedPosts = allPosts.filter((post) => import.meta.env.DEV || post.data.draft !== true);
const showNotesLink = publishedPosts.length > 0;

const navLinks = headerData.links.filter((link) => {
  if (link.text === 'Notes') {
    return showNotesLink;
  }
  return true;
});
---

<header class="sticky top-0 z-50 bg-paper border-b border-hairline" data-aw-sticky-header id="header">
  <nav class="max-w-6xl mx-auto px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <Logo />

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-7">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'relative py-1 text-sm transition-colors',
                isActive(link.href) ? 'text-amber' : 'text-ink hover:text-amber',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.text}
              {isActive(link.href) && <span class="absolute -bottom-px left-0 right-0 h-px bg-amber" />}
            </a>
          ))
        }
      </div>

      <!-- Mobile Menu Toggle -->
      <div class="flex items-center lg:hidden">
        <button
          id="mobile-menu-button"
          type="button"
          class="p-2 text-ink hover:text-amber"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Toggle navigation menu"
          data-aw-toggle-menu
        >
          <svg class="w-6 h-6 menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
          <svg
            class="w-6 h-6 close-icon hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation Menu -->
    <div id="mobile-menu" class="lg:hidden hidden pb-6 pt-4 border-t border-hairline" aria-label="Mobile navigation">
      <div class="flex flex-col gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'block py-2 text-base transition-colors',
                isActive(link.href) ? 'text-amber' : 'text-ink hover:text-amber',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.text}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<script>
  let isMobileMenuInitialized = false;

  function initMobileMenu() {
    if (isMobileMenuInitialized) return;

    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!menuButton || !mobileMenu) return;

    isMobileMenuInitialized = true;

    menuButton.setAttribute('aria-expanded', 'false');
    mobileMenu.classList.add('hidden');

    function closeMenu() {
      if (!menuButton || !mobileMenu) return;
      menuButton.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.add('hidden');
    }

    function openMenu() {
      if (!menuButton || !mobileMenu) return;
      menuButton.setAttribute('aria-expanded', 'true');
      mobileMenu.classList.remove('hidden');
    }

    menuButton.addEventListener('click', () => {
      const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          closeMenu();
          menuButton.focus();
        }
      }
    });
  }

  initMobileMenu();

  document.addEventListener('astro:after-swap', () => {
    isMobileMenuInitialized = false;
    initMobileMenu();
  });
</script>
