---
import type { Headline as Props } from '~/types';
import { twMerge } from 'tailwind-merge';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  marker,
  classes = {},
} = Astro.props;

const {
  container: containerClass = 'max-w-3xl',
  title: titleClass = 'text-3xl md:text-4xl ',
  subtitle: subtitleClass = 'text-xl',
} = classes;
---

{
  (title || subtitle || tagline || marker) && (
    <div class={twMerge('mb-8 md:mx-auto md:mb-12 text-center', containerClass)}>
      {marker && (
        <div class="nb-section-marker">
          <span class="marker">{marker}</span>
          <span class="rule" />
        </div>
      )}
      {tagline && (
        <p class="text-base text-ink-muted font-medium tracking-wide uppercase mono-label" set:html={tagline} />
      )}
      {title && <h2 class={twMerge('text-ink-heading text-3xl', titleClass)} set:html={title} />}

      {subtitle && <p class={twMerge('mt-4 text-ink-muted', subtitleClass)} set:html={subtitle} />}
    </div>
  )
}
