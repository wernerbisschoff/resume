---
import '@fontsource-variable/geist-mono';
---

<!-- Typography and theme styles for the Engineer's Notebook aesthetic -->
<style is:inline>
  /*
   * FONT STRATEGY
   * -----------------------------------------------------------
   * h1 + section markers (.pixel-marker): Geist Pixel Circle
   * Everything else (body, h2, h3, nav, buttons, labels, code):
   *   Geist Mono Variable, weighted (400 body / 500 labels / 600-700 headings).
   */

  /* Geist Pixel Circle — only for the wordmark and section markers */
  @font-face {
    font-family: 'Geist Pixel Circle';
    font-style: normal;
    font-display: swap;
    font-weight: 400;
    src: url('/fonts/geist-pixel/GeistPixel-Circle.woff2') format('woff2');
  }

  :root {
    --aw-font-sans: 'Geist Mono Variable', 'Geist Mono', monospace;
    --aw-font-heading: 'Geist Pixel Circle', 'Geist Mono Variable', monospace;
    --aw-font-mono: 'Geist Mono Variable', 'Geist Mono', monospace;

    /* Letter spacing tokens — engineering precision */
    --aw-tracking-tighter: -0.02em;
    --aw-tracking-tight: -0.01em;
    --aw-tracking-normal: 0;
    --aw-tracking-wide: 0.02em;
    --aw-tracking-wider: 0.06em;

    /* Type scale */
    --aw-text-xs: 0.75rem;
    --aw-text-sm: 0.875rem;
    --aw-text-base: 1rem;
    --aw-text-lg: 1.125rem;
    --aw-text-xl: 1.375rem;
    --aw-text-2xl: 1.75rem;
    --aw-text-3xl: 2.25rem;
    --aw-text-4xl: 3rem;
  }

  /* Base body — proper case, comfortable reading */
  body {
    font-family: var(--aw-font-sans);
    font-weight: 400;
    font-optical-sizing: auto;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    line-height: 1.7;
    color: var(--aw-ink);
    background-color: var(--aw-paper);
  }

  /*
   * HEADINGS
   * Pixel Circle reserved for the page h1 only — it's the site's signature.
   * h2 / h3 use Geist Mono Variable with weight, so we get a strong,
   * mono-feeling hierarchy without overusing the pixel font.
   */

  /* h1 — Geist Pixel Circle, single weight */
  h1,
  .h1 {
    font-family: var(--aw-font-heading);
    font-weight: 400;
    font-size: var(--aw-text-4xl);
    line-height: 1.1;
    letter-spacing: 0.01em;
    color: var(--aw-ink-heading);
    text-transform: none;
  }
  @media (max-width: 768px) {
    h1,
    .h1 {
      font-size: var(--aw-text-3xl);
    }
  }

  /* h2 — Geist Mono Variable SemiBold */
  h2,
  .h2 {
    font-family: var(--aw-font-sans);
    font-weight: 600;
    font-size: var(--aw-text-2xl);
    line-height: 1.3;
    letter-spacing: var(--aw-tracking-tight);
    color: var(--aw-ink-heading);
    text-transform: none;
  }
  @media (min-width: 768px) {
    h2,
    .h2 {
      font-size: var(--aw-text-3xl);
    }
  }

  /* h3 — Geist Mono Variable SemiBold, smaller */
  h3,
  .h3 {
    font-family: var(--aw-font-sans);
    font-weight: 600;
    font-size: var(--aw-text-lg);
    line-height: 1.4;
    letter-spacing: var(--aw-tracking-tight);
    color: var(--aw-ink-heading);
    text-transform: none;
  }
  @media (min-width: 768px) {
    h3,
    .h3 {
      font-size: var(--aw-text-xl);
    }
  }

  /*
   * Pixel Circle utility — used sparingly for section markers.
   * Pair with .nb-section-marker for the printed-manual layout.
   */
  .pixel-marker {
    font-family: var(--aw-font-heading);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--aw-accent-amber);
    text-transform: none;
  }

  /* Mono labels — for section eyebrows, metadata, category tags */
  .mono-label {
    font-family: var(--aw-font-sans);
    font-weight: 500;
    font-size: var(--aw-text-xs);
    letter-spacing: var(--aw-tracking-wider);
    text-transform: uppercase;
    color: var(--aw-ink-muted);
  }

  /* Mono body labels — slightly heavier for inline emphasis */
  .font-mono,
  code,
  pre {
    font-family: var(--aw-font-mono);
    font-weight: 500;
    letter-spacing: var(--aw-tracking-normal);
    text-transform: none;
  }

  /* Mono inline code — paper-raised background, hairline border */
  :not(pre) > code {
    background-color: var(--aw-paper-raised);
    border: 1px solid var(--aw-hairline);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.9em;
    color: var(--aw-accent-amber);
  }

  /* Pixel art — preserve crisp pixels, no smoothing on scale */
  .pixel-art {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }

  /* Code blocks */
  /* Code blocks — site surface; Astro/Shiki inline spans own token color */
  pre,
  pre.astro-code {
    background-color: var(--aw-paper-raised) !important;
    color: var(--aw-ink) !important;
    border: 1px solid var(--aw-hairline);
    padding: 1rem;
    overflow-x: auto;
    line-height: 1.55;
  }
  pre code,
  .astro-code code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  /* Nav links and buttons — Geist Mono with weight */
  nav a,
  button {
    font-family: var(--aw-font-sans);
    font-weight: 500;
    letter-spacing: var(--aw-tracking-normal);
    text-transform: none;
  }

  /* Buttons get a slightly heavier treatment */
  button {
    font-weight: 600;
    letter-spacing: var(--aw-tracking-wide);
  }

  /* Nav stays lighter for body-text feel */
  nav a {
    font-weight: 500;
    letter-spacing: var(--aw-tracking-normal);
  }

  /* Restrained, paper-friendly transitions */
  body,
  header,
  footer,
  main,
  section,
  nav,
  a,
  button,
  input,
  textarea,
  select {
    transition:
      background-color 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }

  /* Focus visible — amber outline, no glow */
  :focus-visible {
    outline: 2px solid var(--aw-accent-amber);
    outline-offset: 2px;
  }
  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  textarea:focus-visible,
  select:focus-visible {
    outline: 2px solid var(--aw-accent-amber);
    outline-offset: 2px;
  }

  /* Selection — amber on paper */
  ::selection {
    background-color: var(--aw-accent-amber);
    color: var(--aw-paper);
  }

  /* Links inside prose get an underline */
  .nb-prose a {
    color: var(--aw-accent-amber);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    text-decoration-color: var(--aw-hairline-strong);
    transition: text-decoration-color 0.15s ease;
  }
  .nb-prose a:hover {
    text-decoration-color: var(--aw-accent-amber);
  }
</style>
