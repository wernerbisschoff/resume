---
import '@fontsource-variable/inter';
import '@fontsource-variable/azeret-mono';
---

<!-- Typography and theme styles -->
<style is:inline>
  /*
   * FONT STRATEGY: "The Technical Manifest" (Full Mono Headings)
   * -----------------------------------------------------------
   * H1-H3: Azeret Mono - Pure engineering identity, zero filler
   * Body: Inter Variable - High-readability content for long-form reading
   * Nav/Labels/Buttons: Azeret Mono - Professional, consistent interface
   */
  :root {
    --aw-font-sans: 'Inter Variable', 'Inter', system-ui, -apple-system, sans-serif;
    --aw-font-heading: 'Azeret Mono Variable', 'Azeret Mono', monospace;
    --aw-font-mono: 'Azeret Mono Variable', 'Azeret Mono', monospace;

    /* Letter spacing tokens - Precision tuning */
    --aw-tracking-tighter: -0.05em;
    --aw-tracking-tight: -0.02em;
    --aw-tracking-normal: 0;
    --aw-tracking-wide: 0.04em;
    --aw-tracking-wider: 0.08em;
  }

  /* Base typography */
  body {
    font-family: var(--aw-font-sans);
    font-optical-sizing: auto;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    line-height: 1.6;
  }

  /* Global Heading Strategy - Full Mono Manifest */

  /* H1: Azeret Mono - Massive Impact, Extra Bold, All Lowercase */
  h1,
  .h1 {
    font-family: var(--aw-font-heading) !important;
    font-weight: 800;
    letter-spacing: 0.02em; /* Slightly positive tracking for that terminal look */
    line-height: 1.05;
    text-transform: lowercase; /* FORCED LOWERCASE */
    font-variation-settings: 'wght' 800;
  }

  h1:hover {
    font-variation-settings: 'wght' 700;
    transition: font-variation-settings 0.3s ease;
  }

  /* H2, H3: Azeret Mono - Structural, All Lowercase */
  h2,
  h3,
  .h2,
  .h3,
  [class*='font-heading']:not(h1):not(.h1) {
    font-family: var(--aw-font-mono) !important;
    font-weight: 700;
    letter-spacing: var(--aw-tracking-tight);
    text-transform: lowercase; /* FORCED LOWERCASE */
  }

  h2,
  .h2 {
    font-size: 1.875rem; /* 30px */
    line-height: 1.3;
    @media (min-width: 768px) {
      font-size: 2.25rem; /* 36px */
    }
  }

  h3,
  .h3 {
    font-size: 1.5rem; /* 24px */
    line-height: 1.4;
  }

  /* Technical & Actionable elements - Clean, high-tech interface */
  .font-mono,
  code,
  pre,
  .btn,
  button,
  nav a,
  .badge,
  label,
  .text-mono {
    font-family: var(--aw-font-mono);
    font-weight: 500;
    letter-spacing: var(--aw-tracking-normal);
    text-transform: lowercase; /* FORCED LOWERCASE */
  }

  /* Buttons - Precision interaction */
  .btn,
  button {
    font-weight: 700;
    text-transform: lowercase; /* FORCED LOWERCASE */
    letter-spacing: var(--aw-tracking-wide);
    border-radius: 0.125rem;
  }

  /* Navigation - Sleek, low-level feel */
  nav a {
    font-weight: 600;
    text-transform: lowercase;
    letter-spacing: var(--aw-tracking-normal);
  }

  /* Smooth transitions for theme switching */
  body,
  header,
  footer,
  main,
  section,
  nav,
  a,
  button,
  input,
  textarea,
  select {
    transition:
      background-color 0.25s ease,
      color 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  /* Subtle grain texture overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  /* Custom selection styling */
  ::selection {
    background-color: var(--aw-color-primary, #d4a84a);
    color: #0d0d0d;
  }
</style>
