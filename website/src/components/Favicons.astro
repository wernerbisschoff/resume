---
/**
 * Favicons — uses the original pixel-profile.png without sips conversion
 * to preserve pixel-perfect clarity. The browser scales the PNG natively.
 */
import pixelProfile from '~/assets/favicons/pixel-profile.png';
---

<link rel="icon" type="image/png" href={pixelProfile.src} />
<link rel="apple-touch-icon" href={pixelProfile.src} />
