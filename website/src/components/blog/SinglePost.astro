---
import { Icon } from 'astro-icon/components';

import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';
import { CONTACT_INFO } from '~/config/contact';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
---

<section class="py-8 sm:py-16 lg:py-20 mx-auto">
  <article>
    <header>
      <div
        class="flex justify-between flex-col sm:flex-row max-w-3xl mx-auto mt-0 mb-2 px-4 sm:px-6 sm:items-center font-mono text-sm text-ink-muted"
      >
        <p>
          <Icon name="tabler:clock" class="w-4 h-4 inline-block -mt-0.5" aria-hidden="true" />
          <time datetime={String(post.publishDate)} class="inline-block">{getFormattedDate(post.publishDate)}</time>
          {
            post.category && (
              <>
                <span class="text-ink-faint mx-2" aria-hidden="true">
                  ·
                </span>
                <a class="hover:text-amber" href={getPermalink(post.category.slug, 'category')}>
                  {post.category.title}
                </a>
              </>
            )
          }
          {
            post.readingTime && (
              <>
                <span class="text-ink-faint mx-2" aria-hidden="true">
                  ·
                </span>
                <span>{post.readingTime} min read</span>
              </>
            )
          }
        </p>
      </div>

      {/* Author byline */}
      <p
        class="max-w-3xl mx-auto mt-2 mb-3 px-4 sm:px-6 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm font-mono text-ink-muted"
      >
        <span class="text-ink">
          <span class="text-amber mr-1">&gt;</span> By {CONTACT_INFO.name}
        </span>
        <span class="text-ink-faint" aria-hidden="true">·</span>
        <span>{CONTACT_INFO.jobTitle.replace(' — Available for Contract', '')}, {CONTACT_INFO.location}</span>
      </p>

      <h1 class="px-4 sm:px-6 max-w-3xl mx-auto text-ink-heading">
        {post.title}
      </h1>
      <p class="max-w-3xl mx-auto mt-4 mb-8 px-4 sm:px-6 text-xl md:text-2xl text-ink-muted">
        {post.excerpt}
      </p>

      {
        post.image ? (
          <Image
            src={post.image}
            widths={[400, 900]}
            width={900}
            sizes="(max-width: 900px) 400px, 900px"
            aspectRatio="16:9"
            class="bg-paper-raised border border-hairline"
            alt={post.title}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="border-t border-hairline" />
          </div>
        )
      }
    </header>

    <div
      class="mx-auto px-6 sm:px-6 max-w-3xl prose prose-md lg:prose-xl nb-prose prose-headings:scroll-mt-[80px] prose-li:my-0 mt-8"
    >
      <slot />
    </div>

    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-8 flex justify-between flex-col sm:flex-row">
      {
        post.tags && Array.isArray(post.tags) && (
          <div class="mb-4">
            <PostTags tags={post.tags} />
          </div>
        )
      }
      <SocialShare text={post.title} url={typeof url === 'string' ? url : String(url)} />
    </div>
  </article>
</section>
