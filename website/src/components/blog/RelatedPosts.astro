---
import { APP_BLOG } from 'astrowind:config';

import { getRelatedPosts } from '~/utils/blog';
import type { Post } from '~/types';
import { getBlogPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

const relatedPosts = post.tags ? await getRelatedPosts(post, 4) : [];
---

{
  APP_BLOG.isRelatedPostsEnabled && relatedPosts.length > 0 ? (
    <section class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="pt-8 lg:pt-12 md:pt-8 max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-text-heading mb-6">Related Posts</h2>
        <div class="space-y-6">
          {relatedPosts.map((post) => (
            <a href={post.permalink} class="block group">
              <h3 class="text-xl font-semibold text-text-heading group-hover:text-primary transition-colors">
                {post.title}
              </h3>
            </a>
          ))}
        </div>
        <a href={getBlogPermalink()} class="inline-block mt-6 text-primary hover:underline">
          View All Posts →
        </a>
      </div>
    </section>
  ) : null
}
