---
import { APP_BLOG } from 'astrowind:config';

import { getRelatedPosts } from '~/utils/blog';
import type { Post } from '~/types';
import { getBlogPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

const relatedPosts = post.tags ? await getRelatedPosts(post, 4) : [];
---

{
  APP_BLOG.isRelatedPostsEnabled && relatedPosts.length > 0 ? (
    <section>
      <div class="pt-8 lg:pt-12 md:pt-8 max-w-3xl mx-auto">
        <div class="nb-section-marker">
          <span class="marker">02</span>
          <span class="rule" />
          <span class="label">Related Notes</span>
        </div>
        <h2 class="text-ink-heading mb-6">Related Posts</h2>
        <div class="space-y-6">
          {relatedPosts.map((post) => (
            <a href={post.permalink} class="block group">
              <h3 class="text-xl text-ink-heading group-hover:text-amber transition-colors">{post.title}</h3>
            </a>
          ))}
        </div>
        <a href={getBlogPermalink()} class="inline-block mt-6 text-amber font-mono">
          View All Notes &rarr;
        </a>
      </div>
    </section>
  ) : null
}
