---
/**
 * Footer Component — Engineer's Notebook
 *
 * Single-line footer with location, email, and social links.
 * Hairline border, mono labels, no glow, no scale animation.
 */

import { footerData } from '~/navigation';
import { Icon } from 'astro-icon/components';
---

<footer class="relative border-t border-hairline mt-auto bg-paper">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Location + email -->
      <div class="flex flex-col md:flex-row items-center gap-3 md:gap-6 text-sm font-mono">
        <span class="text-ink-muted">Cape Town, South Africa</span>
        <span class="hidden md:inline text-ink-faint">·</span>
        <a href={`mailto:${footerData.email}`} class="text-ink hover:text-amber">
          {footerData.email}
        </a>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-5">
        {
          footerData.socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="me noopener noreferrer"
              aria-label={social.ariaLabel}
              class="text-ink-muted hover:text-amber"
            >
              <Icon name={social.icon} class="w-5 h-5" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
