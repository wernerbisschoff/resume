---
import Layout from '~/layouts/Layout.astro';
import ScrollReveal from '~/components/anim/ScrollReveal.astro';
import { CONTACT_INFO } from '~/config/contact';
import { getContactPageSchema } from '~/utils/structured-data';

const metadata = {
  title: 'Contact — Werner Bisschoff',
  description:
    'Get in touch to discuss your software engineering needs. Open to freelance, contract, part-time, full-time, and remote work opportunities in Cape Town.',
};

const contactSchema = getContactPageSchema();
---

<Layout metadata={metadata}>
  <!-- ContactPage JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <!-- Header -->
  <section class="no-print relative py-16 px-4 sm:px-6 lg:px-8 border-b border-border/[0.06]">
    <ScrollReveal direction="up" delay={0} duration={0.6}>
      <div class="max-w-4xl mx-auto text-center">
        <span
          class="inline-block px-4 py-2 bg-primary/[0.08] text-primary text-xs font-mono font-semibold tracking-wider rounded-sm mb-6"
        >
          CONTACT
        </span>
        <h1 class="text-4xl sm:text-5xl font-heading font-bold text-text-heading mb-6">
          Tell me about your project.
        </h1>
        <p class="text-lg text-text-muted max-w-2xl mx-auto leading-relaxed">
          I'll let you know if it's a fit and what a timeline looks like. Fill in the form and
          I'll get back to you within 24 hours.
        </p>
      </div>
    </ScrollReveal>
  </section>

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <ScrollReveal direction="up" delay={0.1} duration={0.6}>
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-heading font-semibold text-text-heading mb-6">Send a Message</h2>

          <form
            id="contact-form"
            action="https://formspree.io/f/mlggwjby"
            method="POST"
            data-ajax="true"
            class="space-y-5"
          >
            <!-- Name Field -->
            <div>
              <label for="name" class="block text-sm font-semibold text-text-heading mb-2">
                Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                class="input input-bordered w-full px-4 py-3 bg-bg-element border border-border/[0.1] rounded-sm text-text-heading placeholder-text-muted/50 focus:border-primary focus:ring-primary"
                placeholder="Your name"
              />
            </div>

            <!-- Email Field -->
            <div>
              <label for="email" class="block text-sm font-semibold text-text-heading mb-2">
                Email <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="input input-bordered w-full px-4 py-3 bg-bg-element border border-border/[0.1] rounded-sm text-text-heading placeholder-text-muted/50 focus:border-primary focus:ring-primary"
                placeholder="your@email.com"
              />
            </div>

            <!-- Message Field -->
            <div>
              <label for="message" class="block text-sm font-semibold text-text-heading mb-2">
                Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                minlength="10"
                rows="6"
                class="textarea textarea-bordered w-full px-4 py-3 bg-bg-element border border-border/[0.1] rounded-sm text-text-heading placeholder-text-muted/50 focus:border-primary focus:ring-primary resize-none"
                placeholder="Brief description of your project or needs. What problem are you solving, and what kind of timeline are you working with?"></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              id="submit-btn"
              class="btn btn-primary w-full px-6 py-3.5 font-semibold text-sm tracking-wide rounded-sm hover:shadow-lg hover:shadow-primary/30 transition-all duration-300 hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
            >
              <span id="btn-text">Start the Conversation</span>
              <svg id="btn-spinner" class="hidden animate-spin w-5 h-5 mx-auto" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path>
              </svg>
            </button>

            <!-- Status Messages -->
            <div id="form-status" class="hidden" role="alert" aria-live="polite"></div>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-heading font-semibold text-text-heading mb-6">Other Ways to Connect</h2>

            <!-- Email -->
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-text-heading mb-3 flex items-center">
                <svg
                  class="w-5 h-5 text-primary mr-2"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                Email
              </h3>
              <a
                href={`mailto:${CONTACT_INFO.email}`}
                class="text-text-muted hover:text-primary transition-colors font-mono"
              >
                {CONTACT_INFO.email}
              </a>
            </div>

            <!-- Location -->
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-text-heading mb-3 flex items-center">
                <svg
                  class="w-5 h-5 text-primary mr-2"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Location
              </h3>
              <p class="text-text-muted">Cape Town, South Africa</p>
            </div>

            <!-- Social Links -->
            <div>
              <h3 class="text-sm font-semibold text-text-heading mb-3 flex items-center">
                <svg
                  class="w-5 h-5 text-primary mr-2"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                  ></path>
                </svg>
                Social
              </h3>
              <div class="flex flex-wrap gap-4">
                <a
                  href={CONTACT_INFO.social.github.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="GitHub Profile"
                  class="inline-flex items-center px-4 py-2 bg-bg-element border border-border/20 rounded-sm text-text-muted hover:text-primary hover:border-primary transition-all duration-300"
                >
                  <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                    <path
                      fill-rule="evenodd"
                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                      clip-rule="evenodd"></path>
                  </svg>
                  GitHub
                </a>

                <a
                  href={CONTACT_INFO.social.linkedin.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="LinkedIn Profile"
                  class="inline-flex items-center px-4 py-2 bg-bg-element border border-border/20 rounded-sm text-text-muted hover:text-primary hover:border-primary transition-all duration-300"
                >
                  <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                    <path
                      d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                    ></path>
                  </svg>
                  LinkedIn
                </a>
              </div>
            </div>
          </div>

          <!-- Availability -->
          <div class="p-5 bg-bg-element/30 border-l-4 border-primary">
            <h3 class="text-base font-heading font-semibold text-text-heading mb-2">Current Availability</h3>
            <p class="text-text-muted text-sm leading-relaxed">
              Currently accepting new projects. I'll get back to you within 24 hours — let's discuss how I can
              help strengthen your engineering foundations.
            </p>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </main>
</Layout>

<script is:inline define:vars={{ contactEmail: CONTACT_INFO.email }}>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  const formStatus = document.getElementById('form-status');

  if (form && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Show loading state
      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');

      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            Accept: 'application/json',
          },
          body: new URLSearchParams(formData).toString(),
        });

        if (response.ok) {
          // Success
          formStatus.textContent = "Thank you! Your message has been sent successfully. I'll get back to you soon.";
          formStatus.className = 'alert alert-success p-4 rounded-sm';
          formStatus.classList.remove('hidden');
          form.reset();
        } else {
          throw new Error('Form submission failed');
        }
      } catch {
        // Error
        formStatus.textContent = `Oops! Something went wrong. Please try again or email me directly at ${contactEmail}`;
        formStatus.className = 'alert alert-error p-4 rounded-sm';
        formStatus.classList.remove('hidden');
      } finally {
        // Reset button state
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');

        // Scroll to status message
        formStatus.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  }
</script>
