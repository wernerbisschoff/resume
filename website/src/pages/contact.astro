---
import Layout from '~/layouts/Layout.astro';
import { CONTACT_INFO } from '~/config/contact';
import { getContactPageSchema } from '~/utils/structured-data';

const metadata = {
  title: 'Werner Bisschoff — Contact',
  description:
    'Contact Werner Bisschoff for embedded systems, systems engineering, infrastructure engineering, test-driven development, and agentic AI workflows. Open to freelance, contract, part-time, full-time, and remote work in Cape Town or internationally.',
  ignoreTitleTemplate: true,
};
const contactSchema = getContactPageSchema();
---

<Layout metadata={metadata}>
  <!-- ContactPage JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <!-- Header -->
  <section class="no-print relative py-16 px-4 sm:px-6 lg:px-8 border-b border-hairline">
    <div class="max-w-4xl mx-auto">
      <div class="nb-section-marker mb-6">
        <span class="marker">§</span>
        <span class="rule"></span>
        <span class="label">Contact</span>
      </div>
      <h1 class="mb-6 text-left">Tell me about your project.</h1>
      <p class="text-lg text-ink-muted max-w-2xl leading-relaxed">
        I'll let you know if it's a fit and what a timeline looks like. Fill in the form and I'll get back to you within
        24 hours.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div>
        <div class="nb-section-marker">
          <span class="marker">01</span>
          <span class="rule"></span>
          <span class="label">Send a Message</span>
        </div>
        <h2 class="mb-6">Send a Message</h2>

        <form
          id="contact-form"
          action="https://formspree.io/f/mlggwjby"
          method="POST"
          data-ajax="true"
          class="space-y-5"
        >
          <!-- Name Field -->
          <div>
            <label for="name" class="block text-sm font-medium text-ink-heading mb-2">
              Name <span class="text-[#8a2a1a]">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              minlength="2"
              class="w-full px-4 py-3 bg-paper border border-hairline text-ink placeholder-ink-faint focus:border-amber focus:outline-none focus:ring-0"
              placeholder="Your name"
            />
          </div>

          <!-- Email Field -->
          <div>
            <label for="email" class="block text-sm font-medium text-ink-heading mb-2">
              Email <span class="text-[#8a2a1a]">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-paper border border-hairline text-ink placeholder-ink-faint focus:border-amber focus:outline-none focus:ring-0"
              placeholder="your@email.com"
            />
          </div>

          <!-- Message Field -->
          <div>
            <label for="message" class="block text-sm font-medium text-ink-heading mb-2">
              Message <span class="text-[#8a2a1a]">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              minlength="10"
              rows="6"
              class="w-full px-4 py-3 bg-paper border border-hairline text-ink placeholder-ink-faint focus:border-amber focus:outline-none focus:ring-0 resize-none"
              placeholder="What problem are you solving and what's your timeline?"></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full inline-flex items-center justify-center gap-2.5 px-7 py-3.5 bg-ink-heading text-paper font-medium text-base tracking-wide transition-colors duration-150 hover:bg-amber disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="btn-text">Start the Conversation</span>
            <svg id="btn-spinner" class="hidden animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg>
          </button>

          <!-- Status Messages -->
          <div id="form-status" class="hidden" role="alert" aria-live="polite"></div>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="space-y-8">
        <div>
          <div class="nb-section-marker">
            <span class="marker">02</span>
            <span class="rule"></span>
            <span class="label">Other Ways to Connect</span>
          </div>
          <h2 class="mb-6">Other Ways to Connect</h2>
          <!-- Email -->
          <div class="mb-6">
            <h3 class="text-sm font-medium text-ink-heading mb-3 font-mono">
              <span class="text-amber mr-2">@</span>Email
            </h3>
            <a
              href={`mailto:${CONTACT_INFO.email}`}
              class="text-ink-muted hover:text-ink-heading transition-colors duration-150 font-mono"
            >
              {CONTACT_INFO.email}
            </a>
          </div>

          <!-- Location -->
          <div class="mb-6">
            <h3 class="text-sm font-medium text-ink-heading mb-3 font-mono">
              <span class="text-amber mr-2">{'>'}</span>Location
            </h3>
            <p class="text-ink-muted">Cape Town, South Africa</p>
          </div>

          <!-- Social Links -->
          <div>
            <h3 class="text-sm font-medium text-ink-heading mb-3 font-mono">
              <span class="text-amber mr-2">#</span>Social
            </h3>
            <div class="flex flex-wrap gap-4">
              <a
                href={CONTACT_INFO.social.github.url}
                target="_blank"
                rel="me noopener noreferrer"
                aria-label="GitHub Profile"
                class="inline-flex items-center px-4 py-2 bg-transparent border border-hairline text-ink-muted transition-colors duration-150 hover:border-amber hover:text-ink-heading"
              >
                GitHub
              </a>

              <a
                href={CONTACT_INFO.social.linkedin.url}
                target="_blank"
                rel="me noopener noreferrer"
                aria-label="LinkedIn Profile"
                class="inline-flex items-center px-4 py-2 bg-transparent border border-hairline text-ink-muted transition-colors duration-150 hover:border-amber hover:text-ink-heading"
              >
                LinkedIn
              </a>
            </div>
          </div>
        </div>

        <!-- Availability -->
        <div class="p-5 bg-paper-raised border border-hairline">
          <h3 class="text-base font-medium text-ink-heading mb-2">Current Availability</h3>
          <p class="text-ink-muted text-sm leading-relaxed">
            Currently accepting new projects. I'll get back to you within 24 hours — let's discuss how I can help
            strengthen your engineering foundations.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script is:inline define:vars={{ contactEmail: CONTACT_INFO.email }}>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  const formStatus = document.getElementById('form-status');

  if (form && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Show loading state
      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');

      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            Accept: 'application/json',
          },
          body: new URLSearchParams(formData).toString(),
        });

        if (response.ok) {
          // Success
          formStatus.textContent = "Thank you! Your message has been sent successfully. I'll get back to you soon.";
          formStatus.className = 'border border-[#4a6e2a] bg-paper-raised text-ink p-4';
          formStatus.classList.remove('hidden');
          form.reset();
        } else {
          throw new Error('Form submission failed');
        }
      } catch {
        // Error
        formStatus.textContent = `Oops! Something went wrong. Please try again or email me directly at ${contactEmail}`;
        formStatus.className = 'border border-[#8a2a1a] bg-paper-raised text-ink p-4';
        formStatus.classList.remove('hidden');
      } finally {
        // Reset button state
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');

        // Scroll to status message
        formStatus.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  }
</script>
