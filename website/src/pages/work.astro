---
import Layout from '~/layouts/Layout.astro';
import fs from 'node:fs';
import yaml from 'js-yaml';

const metadata = {
  title: 'Werner Bisschoff — Selected Work',
  description:
    'Werner Bisschoff is a Cape Town software engineer whose case studies span systems engineering, infrastructure engineering, embedded systems, and test-driven development with agentic AI workflows. Available for contract and remote work.',
  ignoreTitleTemplate: true,
};

// Load canonical data from YAML
const starStories = yaml.load(fs.readFileSync('../content/star-stories.yaml', 'utf-8')) as StarStory[];

interface StarStory {
  id: string;
  situation: string;
  task: string;
  action: string;
  result: string;
  metrics?: string[];
}

interface CaseStudy {
  id: string;
  title: string;
  category: string;
  problem: string;
  constraints: string[];
  solution: string;
  outcome: string[];
  tech: string[];
}

interface FeaturedMapping {
  starId: string;
  title: string;
  category: string;
  tech: string[];
  constraints: string[];
}

// Curated selection of STAR stories to feature as case studies
const featuredMappings: FeaturedMapping[] = [
  {
    starId: 'some-ip-performance-investigation',
    title: 'SOME/IP Performance Investigation',
    category: 'Systems Performance',
    tech: ['C++', 'SOME/IP', 'perf', 'Flamegraphs'],
    constraints: [
      "Customers couldn't use the software due to severe latency",
      'Root cause was hidden in complex request handling paths',
      'Required deep profiling without disrupting production traffic',
    ],
  },
  {
    starId: 'docker-development-container',
    title: 'Docker Development Container for Embedded Systems',
    category: 'Development Infrastructure',
    tech: ['Docker', 'Embedded Linux', 'CI/CD', 'Networking'],
    constraints: [
      'Remote teams needed exact hardware environment replication',
      'Manual environment setup led to inconsistencies and slow onboarding',
      'Team skepticism toward local-first Docker approach',
    ],
  },
  {
    starId: 'finite-state-machine-framework',
    title: 'Event-Driven FSM Framework',
    category: 'Embedded Systems',
    tech: ['C++', 'FreeRTOS', 'IoT', 'State Machines'],
    constraints: [
      "Existing C-based approach wasn't memory-safe enough for industrial IoT",
      'Framework needed to be generic enough for customer to adapt to any system',
      'Required modern C++ features — templates, RAII, smart pointers',
    ],
  },
  {
    starId: 'nfc-e-ink-label-app',
    title: 'NFC E-Ink Label Application',
    category: 'Mobile & Hardware',
    tech: ['Expo', 'NFC', 'Android', 'ISO 14443-4', 'APDU'],
    constraints: [
      'Proprietary e-ink display protocol with unknown image format',
      'No documentation available — had to reverse engineer the format',
      'Part of R&D project with tight exploration timeline',
    ],
  },
  {
    starId: 'kintree-crdt-architecture',
    title: 'Kintree CRDT Architecture',
    category: 'Systems Architecture',
    tech: ['Elixir', 'Phoenix', 'LiveView', 'CRDT', 'PostgreSQL', 'Rust'],
    constraints: [
      'Edit locking would create friction for concurrent users',
      'Required efficient full-text search alongside CRDT editing state',
      'Needed real-time sync with sub-second convergence across sessions',
    ],
  },
  {
    starId: 'sdd-framework',
    title: 'Spec-Driven Development Framework',
    category: 'Methodology',
    tech: ['AI Agentic Workflows', 'TDD', 'ATDD', 'Agentic Coding'],
    constraints: [
      'AI-assisted development produced outputs misaligned with intended outcomes',
      'Vibe-coding lacked deterministic guardrails to keep AI on track',
      'Needed a repeatable framework applicable across any project or language',
    ],
  },
  {
    starId: 'astro-website-accessibility',
    title: 'Divergent Tabletop Community Website',
    category: 'Web Development',
    tech: ['Astro', 'WCAG', 'Web Accessibility', 'Lighthouse'],
    constraints: [
      'Community includes sensitive content requiring trigger warnings',
      'Needed WCAG compliance with full keyboard navigation',
      'Had to handle edge cases like invisible Unicode characters in content',
    ],
  },
];

// Build case studies from STAR data
const caseStudies: CaseStudy[] = featuredMappings.map((mapping) => {
  const story = starStories.find((s: StarStory) => s.id === mapping.starId);

  if (!story) {
    console.warn(`STAR story not found: ${mapping.starId}`);
    return {
      id: mapping.starId,
      title: mapping.title,
      category: mapping.category,
      problem: 'Story data not found.',
      constraints: mapping.constraints,
      solution: '',
      outcome: [],
      tech: mapping.tech,
    };
  }

  // Build outcome items from result and metrics
  const outcome: string[] = [story.result];
  if (story.metrics) {
    story.metrics.forEach((m: string) => outcome.push(m));
  }

  // Combine action into a problem statement
  const problem = `${story.situation} ${story.task}`;

  // Combine action + context into solution
  const solution = story.action;

  return {
    id: mapping.starId,
    title: mapping.title,
    category: mapping.category,
    problem,
    constraints: mapping.constraints,
    solution,
    outcome,
    tech: mapping.tech,
  };
});

// Sub-section labels for the case-study detail pages
const detailSubsections = [
  { number: '01', label: 'Problem' },
  { number: '02', label: 'Constraints' },
  { number: '03', label: 'Solution' },
  { number: '04', label: 'Outcome' },
] as const;
---

<Layout metadata={metadata}>
  <!-- § 00 — Page Header -->
  <section class="px-6 sm:px-8 lg:px-12 py-16 border-b border-hairline">
    <div class="max-w-4xl mx-auto">
      <div class="nb-section-marker">
        <span class="marker">00</span>
        <span class="rule"></span>
        <span class="label">Page Header</span>
      </div>
      <p class="mono-label text-amber mb-3">Case Studies</p>
      <h1 class="mb-6">Selected Work</h1>
      <p class="text-lg text-ink-muted leading-relaxed max-w-2xl">
        Selected projects spanning embedded systems, infrastructure engineering, and agentic AI workflows.
      </p>
    </div>
  </section>

  <!-- § 01 — Case Study Index -->
  <section id="case-studies" class="px-6 sm:px-8 lg:px-12 py-16 border-b border-hairline">
    <div class="max-w-7xl mx-auto">
      <div class="nb-section-marker">
        <span class="marker">01</span>
        <span class="rule"></span>
        <span class="label">Index</span>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          caseStudies.map((study) => (
            <a
              href={`#study-${study.id}`}
              class="group flex flex-col h-full p-6 bg-paper border border-hairline transition-colors duration-150 hover:border-hairline-strong"
            >
              <span class="font-mono text-xs text-amber uppercase tracking-wider mb-4">{study.category}</span>

              <h2 class="text-lg font-semibold text-ink-heading mb-3 break-words transition-colors duration-150 group-hover:text-amber">
                {study.title}
              </h2>

              <p class="text-ink-muted text-sm leading-relaxed line-clamp-3 mb-6">{study.problem}</p>

              <div class="flex flex-wrap gap-2 mb-6">
                {study.tech.slice(0, 3).map((t) => (
                  <span class="font-mono text-xs text-ink-muted px-2 py-1 border border-hairline">{t}</span>
                ))}
              </div>

              <span class="font-mono text-sm text-amber mt-auto">View Case Study →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- § 02–08 — Detailed Case Studies -->
  {
    caseStudies.map((study, index) => {
      const sectionNumber = String(index + 2).padStart(2, '0');
      return (
        <section id={`study-${study.id}`} class="px-6 sm:px-8 lg:px-12 py-20 border-t border-hairline scroll-mt-20">
          <div class="max-w-4xl mx-auto">
            {/* Section header */}
            <div class="nb-section-marker">
              <span class="marker">{sectionNumber}</span>
              <span class="rule" />
              <span class="label">{study.category}</span>
            </div>

            <h2 class="h1 mb-6">{study.title}</h2>

            <div class="flex flex-wrap gap-2 mb-16">
              {study.tech.map((t) => (
                <span class="font-mono text-xs text-ink-muted px-2.5 py-1 border border-hairline">{t}</span>
              ))}
            </div>

            {/* 01 Problem */}
            <div class="mb-12">
              <div class="nb-section-marker">
                <span class="marker">{detailSubsections[0].number}</span>
                <span class="rule" />
                <span class="label">{detailSubsections[0].label}</span>
              </div>
              <h3 class="mb-4">{detailSubsections[0].label}</h3>
              <p class="text-ink-muted text-lg leading-relaxed">{study.problem}</p>
            </div>

            {/* 02 Constraints */}
            {'constraints' in study && study.constraints && (
              <div class="mb-12">
                <div class="nb-section-marker">
                  <span class="marker">{detailSubsections[1].number}</span>
                  <span class="rule" />
                  <span class="label">{detailSubsections[1].label}</span>
                </div>
                <h3 class="mb-4">{detailSubsections[1].label}</h3>
                <ul class="space-y-3 list-none">
                  {study.constraints.map((constraint) => (
                    <li class="flex items-start text-ink-muted text-lg leading-relaxed gap-3">
                      <span class="text-amber shrink-0 font-mono" aria-hidden="true">
                        ▸
                      </span>
                      <span>{constraint}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* 03 Solution */}
            <div class="mb-12">
              <div class="nb-section-marker">
                <span class="marker">{detailSubsections[2].number}</span>
                <span class="rule" />
                <span class="label">{detailSubsections[2].label}</span>
              </div>
              <h3 class="mb-4">{detailSubsections[2].label}</h3>
              <p class="text-ink-muted text-lg leading-relaxed">{study.solution}</p>
            </div>

            {/* 04 Outcome */}
            {'outcome' in study && study.outcome && (
              <div class="mb-12">
                <div class="nb-section-marker">
                  <span class="marker">{detailSubsections[3].number}</span>
                  <span class="rule" />
                  <span class="label">{detailSubsections[3].label}</span>
                </div>
                <h3 class="mb-4">{detailSubsections[3].label}</h3>
                <ul class="space-y-3 list-none">
                  {study.outcome.map((result) => (
                    <li class="flex items-start text-ink-muted text-lg leading-relaxed gap-3">
                      <span class="text-amber shrink-0 font-mono" aria-hidden="true">
                        ▸
                      </span>
                      <span>{result}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* Back to Case Studies */}
            <div class="mt-16 pt-8 border-t border-hairline">
              <a
                href="#case-studies"
                class="font-mono text-sm text-amber hover:text-ink-heading transition-colors duration-150 inline-flex items-center gap-2"
              >
                <span aria-hidden="true">↑</span>
                Back to Case Studies
              </a>
            </div>
          </div>
        </section>
      );
    })
  }
</Layout>
