---
import Layout from '~/layouts/Layout.astro';
import fs from 'node:fs';
import yaml from 'js-yaml';

const metadata = {
  title: 'Werner Bisschoff — Resume',
  description:
    'Werner Bisschoff is a Cape Town software engineer with a B.Eng. in Computer and Electronic Engineering. Resume covers systems engineering, infrastructure engineering, embedded systems, test-driven development, and agentic AI workflows. Open to freelance, contract, part-time, full-time, and remote work.',
  ignoreTitleTemplate: true,
};
interface Config {
  name: string;
  title: Record<string, string>;
  contact: Record<string, string>;
  summary: Record<string, string>;
}

// Load canonical YAML data
const config = yaml.load(fs.readFileSync('../content/config.yaml', 'utf-8')) as Config;
const experiences = yaml.load(fs.readFileSync('../content/experience.yaml', 'utf-8'));
const skillsData = yaml.load(fs.readFileSync('../content/skills.yaml', 'utf-8'));
const educationData = yaml.load(fs.readFileSync('../content/education.yaml', 'utf-8'));

interface Bullet {
  text: string;
  variant: string;
  cv_priority: number;
  website_show: boolean;
  star_ref: number | null;
}

interface ExperienceEntry {
  company: string;
  location: string;
  role: Record<string, string>;
  start_date: string;
  end_date: string | null;
  bullets: Bullet[];
}

interface SkillCategory {
  category: string;
  items: string[];
  variant: string;
}

interface EducationEntry {
  institution: string;
  degree: string;
  start_date: string;
  end_date: string;
}

// Build experience list: all website_show bullets across all variants
const websiteExperiences = (experiences as ExperienceEntry[]).map((exp) => {
  const title = exp.role?.general || Object.values(exp.role)[0];
  const period = `${exp.start_date} — ${exp.end_date || 'Present'}`;
  const description = exp.bullets
    .filter((b) => b.website_show !== false)
    .sort((a, b) => a.cv_priority - b.cv_priority)
    .map((b) => b.text);

  return { title, company: exp.company, period, description };
});

// Build skill categories from general variant only
const websiteSkills = (skillsData as SkillCategory[])
  .filter((s) => s.variant === 'general')
  .map((s) => ({ category: s.category, skills: s.items }));

// Education
const edu = (educationData as EducationEntry[])[0];
const name = config?.name || 'Werner Bisschoff';
const titleText = config?.title?.general || 'Software Engineer';
---

<Layout metadata={metadata}>
  <div class="resume-container">
    <!-- Header -->
    <section class="no-print relative py-12 px-4 sm:px-6 lg:px-8 border-b border-hairline">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <div class="nb-section-marker mb-4">
            <span class="marker">00</span>
            <span class="rule"></span>
            <span class="label">resume / cv</span>
          </div>
          <h1 class="text-4xl sm:text-5xl text-ink-heading mb-2">{name}</h1>
          <p class="text-lg text-ink-muted font-mono">{titleText}</p>
        </div>
        <a
          href="https://github.com/wernerbisschoff/resume/releases/latest/download/W_Bisschoff_CV.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 bg-ink-heading text-paper font-mono font-semibold text-sm tracking-wider hover:bg-amber transition-colors duration-150"
        >
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
          Download PDF
        </a>
      </div>
    </section>
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <section class="mb-12 p-6 bg-paper-raised border border-hairline">
        <p class="text-ink-muted text-base leading-relaxed">
          Practice anchored in
          <strong class="text-ink">test-driven development</strong>,
          <strong class="text-ink">systems engineering</strong>, and
          <strong class="text-ink">agentic AI workflows</strong> — across embedded firmware, cloud infrastructure, and tooling.
        </p>
      </section>

      <section class="mb-16">
        <header>
          <div class="nb-section-marker">
            <span class="marker">01</span>
            <span class="rule"></span>
            <span class="label">Education</span>
          </div>
        </header>
        <h2 class="text-2xl font-semibold text-ink-heading mb-6">Education</h2>
        <div class="p-6 bg-paper-raised border border-hairline border-l-2 border-l-amber">
          <h3 class="text-xl font-semibold text-ink-heading mb-2">
            {edu?.degree || 'B.Eng. Computer and Electronic Engineering'}
          </h3>
          <p class="text-ink-muted mb-3">{edu?.institution || 'North-West University, Potchefstroom'}</p>
          <p class="text-sm text-ink-muted font-mono tracking-wide">{edu?.end_date || '2020'}</p>
        </div>
      </section>

      <!-- Experience Section -->
      <section class="mb-16">
        <header>
          <div class="nb-section-marker">
            <span class="marker">02</span>
            <span class="rule"></span>
            <span class="label">Experience</span>
          </div>
        </header>
        <h2 class="text-2xl font-semibold text-ink-heading mb-6">Experience</h2>

        <div class="relative border-l border-hairline">
          {
            websiteExperiences.map((exp) => (
              <div class="relative pl-6 mb-12 last:mb-0 pb-12 last:pb-0">
                {/* Timeline dot — square 8x8 amber, centered on the rail */}
                <div class="absolute -left-1 top-4 w-2 h-2 bg-amber border border-hairline" />

                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-2">
                  <div>
                    <h3 class="text-xl font-semibold text-ink-heading">{exp.title}</h3>
                    <p class="text-amber font-medium font-mono">{exp.company}</p>
                  </div>
                  <span class="text-sm text-ink-muted font-mono tracking-wide mt-1 sm:mt-0">{exp.period}</span>
                </div>

                <ul class="space-y-2 my-4">
                  {exp.description.map((item) => (
                    <li class="flex items-start text-ink-muted">
                      <span class="text-amber font-mono mr-2 mt-1">{'>'}</span>
                      <span class="leading-relaxed">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Skills Section -->
      <section>
        <header>
          <div class="nb-section-marker">
            <span class="marker">03</span>
            <span class="rule"></span>
            <span class="label">Technical Skills</span>
          </div>
        </header>
        <h2 class="text-2xl font-semibold text-ink-heading mb-6">Technical Skills</h2>

        <div class="grid sm:grid-cols-2 gap-5">
          {
            websiteSkills.map((cat) => (
              <div class="p-5 bg-paper-raised border border-hairline h-full">
                <h3 class="text-base font-semibold text-ink-heading mb-4 tracking-wide font-mono uppercase">
                  {cat.category}
                </h3>
                <div class="flex flex-wrap gap-2">
                  {cat.skills.map((skill) => (
                    <span class="px-2.5 py-1 bg-paper border border-hairline text-sm text-ink-muted font-mono">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  /* Print-friendly styles */
  @media print {
    .no-print,
    header,
    footer,
    button {
      display: none !important;
    }

    body {
      background: white !important;
      color: black !important;
      font-size: 11pt;
      line-height: 1.4;
    }

    .resume-container {
      max-width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    * {
      color: black !important;
    }

    section,
    div {
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
    }

    h2 {
      border-bottom: 2pt solid black !important;
      margin-top: 20pt !important;
      margin-bottom: 10pt !important;
      padding-bottom: 5pt !important;
      page-break-after: avoid;
    }

    h3 {
      page-break-after: avoid;
    }

    .space-y-8 > div {
      page-break-inside: avoid;
    }

    * {
      transition: none !important;
      animation: none !important;
    }

    a {
      text-decoration: underline;
      color: black !important;
    }

    a[href]:after {
      content: ' (' attr(href) ')';
      font-size: 0.8em;
    }

    a[href^='/']:after,
    a[href^='#']:after {
      content: '';
    }
  }

  @media screen {
    html {
      scroll-behavior: smooth;
    }
  }
</style>
