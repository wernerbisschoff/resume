---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = `Error 404`;
---

<Layout metadata={{ title }}>
  <section class="py-16 px-4 sm:px-6 lg:px-8 border-b border-hairline">
    <div class="max-w-4xl mx-auto">
      <div class="nb-section-marker mb-6">
        <span class="marker">01</span>
        <span class="rule"></span>
        <span class="label">not found</span>
      </div>
      <h1 class="mb-6 text-left">404</h1>
      <p class="text-lg text-ink-muted max-w-2xl leading-relaxed mb-3">
        <span class="sr-only">Error</span>
        This route returned no document.
      </p>
      <p class="text-lg text-ink-muted max-w-2xl leading-relaxed mb-8">
        The URL may be malformed, or the resource may have moved.
      </p>
      <a
        rel="noopener noreferrer"
        href={getHomePermalink()}
        class="inline-block border border-hairline px-5 py-2 font-mono text-sm font-medium text-ink hover:border-amber hover:text-amber transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-amber focus-visible:outline-offset-2"
      >
        Back to homepage
      </a>
    </div>
  </section>
</Layout>
