---
import Layout from '~/layouts/Layout.astro';
import portraitImage from '~/assets/images/pixel-profile.png';
import { getKnowledgeGraph, getPersonSchema } from '~/utils/structured-data';

const metadata = {
  title: 'Werner Bisschoff — Software Engineer',
  description:
    'Werner Bisschoff is a software engineer in Cape Town, South Africa, specializing in embedded systems, systems engineering, infrastructure engineering, test-driven development (TDD), and agentic AI workflows. Available for contract and remote work.',
  ignoreTitleTemplate: true,
};

// Single @graph document covering WebSite, ProfilePage, Person, Place, Occupation,
// EducationalOrganization, EducationalOccupationalCredential, and FAQPage.
const knowledgeGraph = getKnowledgeGraph();

// Person schema emitted on its own for sites that don't yet parse @graph nodes.
// Idempotent with the @id inside the knowledge graph.
const personSchema = getPersonSchema();
---

<Layout metadata={metadata}>
  <!-- Single @graph knowledge graph for entity disambiguation -->
  <script type="application/ld+json" set:html={JSON.stringify(knowledgeGraph)} />
  <!-- Person JSON-LD (standalone, @id-linked to the graph) -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- § 00 — Hero -->
  <section class="relative px-4 sm:px-6 lg:px-8 pt-20 pb-16 border-b border-hairline">
    <div class="relative max-w-6xl mx-auto w-full">
      <!-- Row 1: Text + image side by side at lg, stacked below -->
      <div class="flex flex-col lg:flex-row lg:items-center gap-y-10 gap-x-8">
        <div class="flex-1 min-w-0 text-center lg:text-left order-2 lg:order-none">
          <p class="font-mono text-sm text-ink-muted mb-4">Werner Bisschoff</p>
          <h1 class="text-ink-heading leading-[1.1] text-4xl sm:text-5xl md:text-6xl lg:text-7xl">
            Embedded systems to full-stack infrastructure.
          </h1>
          <p class="mt-3 font-mono text-ink-muted text-base sm:text-lg">Spec-driven. Tested. Reliable.</p>
          <p class="mt-6 text-base sm:text-lg text-ink leading-relaxed">
            Werner Bisschoff is a software engineer in Cape Town specializing in
            <span class="text-ink-heading font-semibold">embedded systems</span>,
            <span class="text-ink-heading font-semibold">systems engineering</span>, and
            <span class="text-ink-heading font-semibold">infrastructure engineering</span> — with
            <span class="text-ink-heading font-semibold">test-driven development</span> and
            <span class="text-ink-heading font-semibold">agentic AI workflows</span> as the default practice.
          </p>
        </div>

        <!-- Pixel portrait: 20% larger than the original 169×171 source -->
        <div class="flex justify-center lg:justify-start shrink-0">
          <img
            src={portraitImage.src}
            width={203}
            height={205}
            alt="Werner Bisschoff — pixel portrait, Software Engineer"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="pixel-art block w-[136px] h-[138px] sm:w-[169px] sm:h-[171px] md:w-[203px] md:h-[205px]"
          />
        </div>
      </div>

      <!-- Row 2: Full-width mono labels + tagline + CTAs -->
      <div class="mt-12 text-center">
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 mb-6 font-mono text-xs text-ink-muted">
          <span>B.Eng. Computer and Electronic Engineering</span>
          <span aria-hidden="true" class="text-ink-faint">·</span>
          <span>Available for Contract</span>
        </div>

        <p class="font-mono text-xs text-ink-faint mb-4">Cape Town, South Africa</p>

        <p class="text-base sm:text-lg text-ink-muted max-w-3xl mx-auto mb-8 font-mono leading-relaxed">
          <span class="text-amber">&gt;</span> Embedded Systems
          <span class="text-ink-faint mx-2">|</span>
          Infrastructure Engineering
          <span class="text-ink-faint mx-2">|</span>
          Spec-Driven Development
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center px-7 py-3.5 bg-ink-heading text-paper font-semibold text-base transition-colors duration-150 hover:bg-amber"
          >
            Get in Touch
          </a>
          <a
            href="/work"
            class="inline-block px-7 py-3.5 border border-hairline text-ink font-semibold text-base transition-colors duration-150 hover:border-amber hover:text-amber"
          >
            View My Work
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- § 01 — Engineering Methodology -->
  <section class="relative px-4 sm:px-6 lg:px-8 py-24">
    <div class="max-w-4xl mx-auto">
      <div class="nb-section-marker">
        <span class="marker">01</span>
        <span class="rule"></span>
        <span class="label">Engineering Methodology</span>
      </div>

      <h2 class="text-3xl sm:text-4xl md:text-5xl text-ink-heading mb-6">Spec-first. Tested. No surprises.</h2>
      <p class="text-lg text-ink-muted max-w-2xl mb-12 leading-relaxed">
        I use spec-driven development to guide every tool in the stack — including AI-assisted workflows. Clear
        requirements first, then the right tools for the job.
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <article class="p-6 bg-paper border border-hairline">
          <p class="font-mono text-sm text-amber mb-3">I.</p>
          <h3 class="text-xl font-semibold text-ink-heading mb-2">Spec-Driven</h3>
          <p class="text-ink-muted">
            Clear requirements before any code. Errors caught in specs cost fractions of what they cost in
            implementation.
          </p>
        </article>

        <article class="p-6 bg-paper border border-hairline">
          <p class="font-mono text-sm text-amber mb-3">II.</p>
          <h3 class="text-xl font-semibold text-ink-heading mb-2">Full-Stack Reality</h3>
          <p class="text-ink-muted">
            From C++ firmware on ESP32 to Python backends on AWS. I bridge low-level hardware and cloud infrastructure
            in one delivery.
          </p>
        </article>

        <article class="p-6 bg-paper border border-hairline">
          <p class="font-mono text-sm text-amber mb-3">III.</p>
          <h3 class="text-xl font-semibold text-ink-heading mb-2">TDD-Verified</h3>
          <p class="text-ink-muted">
            Test coverage catches edge cases before they reach production. Quality gates are automated, not
            aspirational.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- § 02 — About / Positioning -->
  <section class="relative px-4 sm:px-6 lg:px-8 py-24 border-t border-hairline">
    <div class="max-w-4xl mx-auto">
      <div class="nb-section-marker">
        <span class="marker">02</span>
        <span class="rule"></span>
        <span class="label">About</span>
      </div>

      <h2 class="text-3xl sm:text-4xl text-ink-heading mb-8">Software Engineer</h2>

      <div class="max-w-3xl space-y-6 mb-16">
        <p class="text-xl text-ink-muted leading-relaxed">
          I bridge the gap between hardware and cloud. From designing event-driven C++ firmware for embedded systems to
          building ERPNext workflows with Python and SQL. Recent work includes cutting firmware bugs through robust FSM
          architectures and bringing engineering rigour to every layer of the stack.
        </p>
        <p class="text-ink-muted text-lg leading-relaxed">
          What sets my work apart is the ability to link low-level hardware (NFC, BLE, CAN bus) to high-level
          applications, driven by a deep curiosity for how systems function from the metal up. I build infrastructure
          that teams can rely on — tested, documented, and designed to handle the edge cases that only experience
          catches.
        </p>
        <p class="text-ink-muted text-lg leading-relaxed">
          Methodology: spec-first design, test-driven development, and continuous delivery built on infrastructure as
          code. Every layer of the stack gets the same rigour — whether it's a PCB trace or a cloud deployment.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 mb-16">
        <article class="p-6 border-l-2 border-l-amber bg-paper-raised">
          <h3 class="text-lg font-semibold text-ink-heading mb-3">
            <span class="pixel-marker">01.</span> Spec-First
          </h3>
          <p class="text-ink-muted">
            Clear specifications are the cheapest bug fix. I invest in requirements before implementation, catching
            errors when they cost minutes instead of weeks.
          </p>
        </article>

        <article class="p-6 border-l-2 border-l-amber bg-paper-raised">
          <h3 class="text-lg font-semibold text-ink-heading mb-3">
            <span class="pixel-marker">02.</span> Hardware to Cloud
          </h3>
          <p class="text-ink-muted">
            Embedded systems, backend services, and infrastructure engineering are not separate disciplines. I bring the
            same systems thinking from the metal up.
          </p>
        </article>

        <article class="p-6 border-l-2 border-l-amber bg-paper-raised">
          <h3 class="text-lg font-semibold text-ink-heading mb-3">
            <span class="pixel-marker">03.</span> Tested Rigour
          </h3>
          <p class="text-ink-muted">
            TDD, automated CI, and infrastructure as code. Quality isn't checked at the end — it's baked into every step
            of the delivery pipeline.
          </p>
        </article>

        <article class="p-6 border-l-2 border-l-amber bg-paper-raised">
          <h3 class="text-lg font-semibold text-ink-heading mb-3">
            <span class="pixel-marker">04.</span> Resilient by Design
          </h3>
          <p class="text-ink-muted">
            From FSMs that handle edge cases to tested workflows. Systems built to function when things get complex, not
            just when they work.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- § 03 — Background -->
  <section class="relative px-4 sm:px-6 lg:px-8 py-24 border-t border-hairline">
    <div class="max-w-3xl mx-auto">
      <div class="nb-section-marker">
        <span class="marker">03</span>
        <span class="rule"></span>
        <span class="label">Background</span>
      </div>

      <h3 class="text-2xl text-ink-heading mb-6">Background</h3>
      <div class="space-y-6">
        <p class="text-ink-muted text-lg leading-relaxed">
          B.Eng. Computer and Electronic Engineering from North-West University (2020). 5+ years bridging embedded
          systems and full-stack development across industries. Automotive Ethernet at UMAN Technologies. Consumer
          electronics firmware at Ingenics/ViVa. Enterprise ERPNext at FARO Africa.
        </p>
        <p class="text-ink-muted text-lg leading-relaxed">
          Currently building Divergent Tabletop, a neurodivergent-focused peer community. Applying systems thinking to
          solve community management challenges through automated software solutions. Always refining my TDD loops for
          more hands-free workflows while maintaining architectural control.
        </p>
      </div>
    </div>
  </section>

  <!-- § 04 — Final CTA -->
  <section class="relative px-4 sm:px-6 lg:px-8 py-24 border-t border-hairline">
    <div class="max-w-3xl mx-auto text-center">
      <div class="nb-section-marker justify-center">
        <span class="marker">04</span>
        <span class="rule"></span>
        <span class="label">Engage</span>
      </div>

      <h2 class="text-3xl sm:text-4xl text-ink-heading mb-6">Ready to build something reliable?</h2>
      <p class="text-xl text-ink-muted mb-12 leading-relaxed">
        Let's discuss how I can help strengthen your engineering foundations.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center px-8 py-4 bg-ink-heading text-paper font-semibold text-lg transition-colors duration-150 hover:bg-amber"
        >
          Start a Conversation
        </a>

        <a
          href="/work"
          class="inline-block px-8 py-4 border border-hairline text-ink font-semibold text-lg transition-colors duration-150 hover:border-amber hover:text-amber"
        >
          See Case Studies
        </a>
      </div>
    </div>
  </section>
</Layout>
