---
import Layout from '~/layouts/PageLayout.astro';
import ScrollReveal from '~/components/anim/ScrollReveal.astro';

import type { MetaData } from '~/types';
import { CONTACT_INFO } from '~/config/contact';

export interface Props {
  frontmatter: {
    title?: string;
    publishDate?: Date;
    updateDate?: Date;
    excerpt?: string;
  };
}

const { frontmatter } = Astro.props;

const metadata: MetaData = {
  title: frontmatter?.title ? `${CONTACT_INFO.name} — ${frontmatter.title}` : CONTACT_INFO.name,
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <ScrollReveal direction="up" delay={0} duration={0.6}>
      <h1 class="text-4xl md:text-5xl leading-tighter tracking-tighter text-ink-heading">{frontmatter.title}</h1>
    </ScrollReveal>

    <div
      class="mx-auto prose prose-lg nb-prose max-w-4xl prose-md prose-a:text-amber prose-img:border prose-img:border-hairline mt-8"
    >
      <slot />
    </div>
  </section>
</Layout>
