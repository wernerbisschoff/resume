#!/bin/bash
# Pre-push hook - Verify build succeeds before sharing code
# NOTE: Root hooks (.githooks/ at repo root) handle monorepo-wide checks.
# This file is a reference for standalone usage.

set -e

echo "🚀 Running pre-push checks..."

echo "Verifying build..."
if mise run build 2>/dev/null; then
    echo "✅ Build verification passed"
else
    echo "❌ Build failed"
    echo "   Fix build errors before pushing"
    exit 1
fi

echo "✅ Pre-push checks passed - ready to push!"
