#!/bin/bash
# Pre-commit hook - Run all validation checks via mise
# NOTE: Root hooks (.githooks/ at repo root) handle monorepo-wide checks.
# This file is a reference for standalone usage.

set -e

echo "🔍 Running pre-commit checks..."
echo "Running validation checks..."

if mise run check 2>/dev/null; then
    echo "✅ Pre-commit checks passed"
else
    echo "❌ Pre-commit checks failed"
    echo "   Run 'mise run check' to see details"
    exit 1
fi
