#!/bin/bash
# Pre-commit hook - Run all validation checks
# Auto-generated by /tools:init - can be regenerated

set -e

echo "🔍 Running pre-commit checks..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Skip if no files are staged
if [ -z "$STAGED_FILES" ]; then
    echo "✅ No files to check"
    exit 0
fi

# Run all check-* targets (format-check, lint, check-types, etc.)
# This dynamically discovers and runs ALL validation checks
echo "Running validation checks..."
if make check 2>/dev/null; then
    echo "✅ Pre-commit checks passed"
else
    echo "❌ Pre-commit checks failed"
    echo "   Run 'make check' to see details, or 'make fix' to auto-fix"
    exit 1
fi
